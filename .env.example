# CAML Research Environment Configuration
# Copy this file to .env and fill in your values

# Base paths
CAML_ROOT=/path/to/caml-research
CAML_SECURE=/path/to/secure
CAML_OUTPUTS=/path/to/caml-research/experiments/linear-probes/outputs

# SSH key for RunPod/StrongCompute access
CAML_SSH_KEY=~/.ssh/runpod_ed25519

# HuggingFace token (for uploading/downloading activations)
HF_TOKEN=hf_xxx

# Anthropic API key (for running experiments)
ANTHROPIC_API_KEY=sk-xxx
